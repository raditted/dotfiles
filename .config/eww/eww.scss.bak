* {
  all: unset;
  font-family: "Monocraft Nerd Font";
}

.bar {
  box-shadow: none;
  border-radius: 0px;
  background-color: rgba(30, 30, 46, 0.6);
  padding: 0px 10px;
  margin: 0px;
}

.menu {
  margin-left: 12px;
}

.menu-eventbox {
  color: #89b4fa;
  transition: color 0.3s;

  &:hover {
    color: #cdd6f4;
  }
}

.power {
  margin-right: 10px;
}

.power-eventbox {
  color: #f38ba8;
  font-weight: bold;
  font-size: 20px;
  font-family: "JetBrainsMono Nerd Font";
  transition: color 0.3s;

  &:hover {
    color: #fab387;
  }
}

.ws {
  font-family: "JetBrainsMono Nerd Font";
  font-size: 16px;
  color: #cdd6f4;
  margin: 1px 0;
}

.ws-btn {
  padding: 0 5px;
  color: #cdd6f4;
  transition: none;
  
  &:hover {
    color: #f5c2e7;
    border-bottom: 1px solid #f5c2e7;
    padding: 0 8px;
  }
}

.visiting {
  color: #f5c2e7;
  border-bottom: 2px solid #f5c2e7;
  padding: 0 8px;
  margin: 0 2px;
}

.free {
  color: #cdd6f4;
  padding: 0 5px;
  opacity: 0.7;
  
  &:hover {
    color: #f5c2e7;
    opacity: 1;
  }
}

.time-label {
  background-color: transparent;
  color: #89b4fa;
  border-radius: 5px;
  padding: 0 10px;
  margin-right: 10px;
  transition: background-color 0.2s;
  &:hover {
    background-color: rgba(88, 91, 112, 0.6);
}

.keyboard,
.battery,
.volume-short,
.ram-short {
  background-color: transparent;
  padding: 0px 10px;
  border-radius: 5px;
  font-size: 13px;
  margin: 1px 0px;
  transition: background-color 0.2s;
  &:hover {
    background-color: rgba(88, 91, 112, 0.6);
  }
}

.volume-short {}

.ram-short {
  color: #89b4fa;
}

.keyboard {
  color: #fab387;
}

.kb-div,
.wifi-div {
  margin: 0px 3px;
}

.kb-type,
.wifi-type {
  color: #cdd6f4;
}

.tray-button {
  font-size: 20px;
  font-family: "JetBrainsMono Nerd Font";
  color: #cdd6f4;
  border-radius: 5px;
  transition: background-color 0.2s;
  &:hover {
    background-color: rgba(88, 91, 112, 0.6);
  }
}
}

.systray-shadow {
  background-color: rgba(0, 0, 0, 0.38);
  margin-right: 5px;
  margin-top: 3px;
  margin-bottom: 3px;
  padding: 0px 8px;
  border-radius: 20px;
}

image {
  margin: 0px 3px;
}

menu {
  border-radius: 15px;
  padding: 10px;
  background-color: red;
  color: #cdd6f4;
  background-color: rgba(0, 0, 0, 0.68);

  menuitem {
    border-radius: 10px;
    padding: 8px 12px;
  }

  menuitem:hover {
    background-color: rgba(70, 70, 220, 0.85);
  }
}

.tray-text {
  margin-bottom: 4px;
}

.wifi {
  background-color: transparent;
  padding: 0px 10px;
  color: #f5c2e7;
  border-radius: 5px;
  font-size: 13px;
  margin: 1px 0px;
  transition: background-color 0.2s;
  &:hover {
    background-color: rgba(88, 91, 112, 0.6);
  }
}

.space-wifi {
  font-size: 4px;
}

.wifictl-container,
.menuctl-container {
  box-shadow: none;
  margin: 5.5px;
  border-radius: 20px;
  min-width: 385px;
  background-color: rgba(30, 30, 46, 0.95);
  padding: 5px;
}

.wifi-header,
.cpu-header,
.menu-header {
  font-size: 25px;
  margin-left: 15px;
  margin-top: 10px;
  margin-bottom: 7px;
  color: #f5c2e7;
}

.wifi-stats,
.menu-subheader {
  color: #cdd6f4;
  margin-left: 15px;
}

.nocon {
  color: #f9e2af;
}

.yescon {
  color: #89b4fa;
}

.network-container,
.app-container {
  min-height: 15rem;
  margin: 7px;
  margin-top: 17px;
  border-radius: 15px;
  box-shadow: none;
  background-color: rgba(69, 71, 90, 0.4);
}

.app-container {
  min-height: 25rem;
}

.wifi-option-box,
.app-option-box {
  font-size: 16px;
  margin: 5px 5px;
  border-radius: 15px;
  padding: 10px;
  background-color: rgba(65, 72, 86, 0.3);
  box-shadow: none;
}

.wifi-ssid {
  margin: 2px 15px;
}

.app-display {
  margin: 2px 2px;
}

.app-name {
  margin-left: 15px;
}

.wifi-ssid-01 {
  color: #f9e2af;
}

.wifi-ssid-02 {
  color: #89b4fa;
}

.wifi-ssid-03 {
  color: #f9e2af;
}

.wifi-buttons {
  color: #cdd6f4;
  border-radius: 10px;
  background-color: rgba(0, 0, 0, 0.52);
}

.wifi-bcon {
  margin: 10px;
}

.iwifi {
  margin-top: 2px;
  margin-left: 10px;
}

.swifi-header {
  font-size: 15px;
  margin-left: 15px;
  margin-top: 10px;
  margin-bottom: 7px;
  color: #f5c2e7;
}

.calendar-container {
  box-shadow: none;
  margin: 5.5px;
  margin-bottom: 10px;
  border-radius: 20px;
  background-color: rgba(30, 30, 46, 0.95);
  padding: 5px;
}

.time-box {
  box-shadow: none;
  border-radius: 15px;
  margin-top: 8px;
  padding-left: 25px;
  padding-right: 25px;
  padding-bottom: 20px;
  background-color: rgba(69, 71, 90, 0.4);
}

.time-inner {
  color: #89b4fa;
  font-size: 50px;
  margin-left: 4px;
  margin-top: 10px;
}

.date-inner {
  color: #cdd4f6;
  margin-top: 20px;
  font-size: 18px;
}

.calendar-box {
  box-shadow: none;
  border-radius: 15px;
  padding-top: 10px;
  padding-left: 10px;
  padding-right: 10px;
  margin-bottom: 9px;
  background-color: rgba(69, 71, 90, 0.4);
}

.cal {
  padding: 5px;
  color: #cdd6f4;

  &.header {
    color: #f9e2af;
  }

  &.button {
    color: #f9e2af;

    &:hover {
      color: #f38ba8;
    }
  }

  &:indeterminate {
    color: rgba(205, 212, 246, 0.4);
  }

  &.highlight {
    color: #fab387;
  }
}

.main-container,
.cpu-container {
  box-shadow: none;
  margin: 5.5px;
  border-radius: 20px;
  min-width: 385px;
  background-color: rgba(30, 30, 46, 0.95);
  padding: 5px;
}

.profile,
.music-container,
.graph-container {
  min-width: 370px;
  margin: 0px 7px;
  margin-top: 5px;
  padding: 10px;
  border-radius: 15px;
  box-shadow: none;
  background-color: rgba(69, 71, 90, 0.4);
}

.graph-container {
  color: #f38ba8;
}

.graph-display {
  min-width: 350px;
}

.main-temp {
  border-radius: 10px;
  background-color: rgba(65, 72, 86, 0.3);
  margin-left: 3px;
  padding: 5px 10px;
}


.pfp {
  box-shadow: none;
  background-image: url('./ikuyo.png');
  background-size: 90px;
  background-position: 50% 35%;
  background-repeat: no-repeat;
  min-height: 90px;
  min-width: 90px;
  border-radius: 100%;
  margin-right: 20px;
}

.username {
  font-size: 30px;
  color: #f5c2e7;
}

.uptime {
  color: #cdd6f4;
}

.minicore-container {
  margin-top: 20px;
  margin-bottom: 5px;
}

.minicores {
  padding: 7px;
}

.C0,
.C1,
.C2,
.C3 {
  margin: 0px 7px;
  padding: 10px;
  border-radius: 15px;
  box-shadow: none;
  background-color: rgba(69, 71, 90, 0.4);
  color: #89b4fa;
}

.ctlpanel {
  min-width: 230px;
  margin-top: 10px;
  border-radius: 20px;
  padding: 5px;
  background-color: rgba(65, 72, 86, 0.3);
  font-family: "JetBrainsMono Nerd Font";
  box-shadow: none;
}

.shutdown {
  color: #e06c75;
  transition: color 0.3s;

  &:hover {
    color: #f38b91;
  }
}

.logout {
  color: #d19a66;
  transition: color 0.3s;

  &:hover {
    color: #e5b07b;
  }
}

.lockscr {
  color: #61afef;
  transition: color 0.3s;

  &:hover {
    color: #79c0ff;
  }
}

.reboot {
  color: #c678dd;
  transition: color 0.3s;

  &:hover {
    color: #d896f0;
  }
}

.suspend {
  color: #56b6c2;
  transition: color 0.3s;

  &:hover {
    color: #6edddf;
  }
}

.hibernate {
  color: #5fb3b3;
  transition: color 0.3s;

  &:hover {
    color: #a1e3e3;
  }
}

tooltip {
  padding: 10px;
  border-radius: 20px;
  background-color: rgba(30, 30, 46, 0.6);
}

.sysctl {
  margin: 0px 7px;
  margin-top: 17px;
  padding: 10px;
  box-shadow: none;
  background-color: rgba(69, 71, 90, 0.4);
  min-width: 370px;
  border-radius: 15px;
}

.BAT1,
.BAT2,
.BAT3 {
  color: #2ECC71;
}

.BAT4,
.BAT5 {
  color: #E74C3C;
}

.CHARGING {
  color: #F1C40F;
}

.batico-main {
  margin-left: 10px;
  margin-right: 15px;
  font-size: 30px;
}

.batico-short {
  margin-right: 6px;
  margin-top: 6px;
}

.volico {
  color: rgb(144, 104, 220);
  margin-left: 3px;
}

.bsht {
  color: #cdd6f4;
}

.bat-percent {
  font-size: 20px;
  color: #cdd6f4;
}

.bat-status {
  color: rgba(255, 255, 255, 0.5)
}

.bat-btn {
  font-size: 13px;
}

.divider-h {
  min-height: 3px;
  margin: 15px 5px;
  background-color: #f38ba8;
}

.sys {
  margin: 0px 10px;
}

.cpu-box,
.ram-box,
.disk-box {
  margin: 0px 10px;
  border-radius: 15px;
  box-shadow: none;
  background-color: rgba(45, 52, 66, 0.3);
}

.cpu,
.ram,
.disk {
  border-radius: 100px;
  margin-top: 20px;
}

.cpu,
.cpu01 {
  color: #f9e2af;
}

.ram,
.ram01 {
  color: #89b4fa;
}

.disk,
.disk01 {
  color: #f5c2e7;
}

.cpu02,
.ram02,
.disk02 {
  color: #cdd6f4;
}

.ramico,
.diskico,
.cpuico {
  margin-right: 15px;
  margin-top: 15px;
  margin-bottom: 15px;
  font-size: 20px;
}

.cpuico {
  margin-left: 20px;
}

.ramico,
.diskico {
  margin-left: 25px;
}

.cpu,
.ram,
.disk {
  background-color: rgb(0, 0, 0);
}

.cpu-text,
.ram-text,
.disk-text {
  margin-bottom: 10px;
}

.ram-text,
.disk-text {
  margin-top: 3.2px;
}

.sliderctl {
  border-radius: 15px;
  box-shadow: none;
  background-color: rgba(45, 52, 66, 0.3);
  margin-left: 20px;
  margin-right: 20px;
  margin-top: 20px;
  margin-bottom: 10px;
}

.monitor-container {
  margin-bottom: 6px;
}

.volume-slider {
  margin-top: 10px;
  margin-left: 13px;
}

.light-slider {
  margin-bottom: 10px;
  margin-left: 13px;
}

.vol trough {
  all: unset;
  background-color: rgba(0, 0, 0, 0.3);
  box-shadow: none;
  border-radius: 50px;
  min-height: 10px;
  min-width: 250px;
  margin: 0 20px 0 20px;
}

.vol trough highlight {
  all: unset;
  background-color: #f5c2e7;
  border-radius: 10px;
}

.volume-slider,
.volume-short {
  color: #f5c2e7;
}

.lig trough {
  all: unset;
  background-color: rgba(0, 0, 0, 0.3);
  box-shadow: none;
  border-radius: 50px;
  min-height: 10px;
  min-width: 250px;
  margin: 0 20px 0 20px;
}

.lig trough highlight {
  all: unset;
  background-color: #f9e2af;
  border-radius: 10px;
}

.light-slider {
  color: #f9e2af;
}

.clear-container {
  margin: 6px 10px;
}

.nheader {
  font-size: 20px;
  color: #cdd6f4;
}

.clear {
  color: #f38ba8;
  font-size: 30px;
  transition: color 0.3s;

  &:hover {
    color: #f9e2af;
  }
}

.music-title {
  margin-left: 7px;
  margin-right: 7px;
  margin-top: 7px;
}

.music-thumbnail {
  background-repeat: no-repeat;
  background-size: cover;
  background-position: center;
  min-height: 6rem;
  min-width: 6rem;
  border-radius: 1rem;
}

.app-ico {
  background-repeat: no-repeat;
  background-size: cover;
  background-position: center;
  min-height: 2.5rem;
  min-width: 2.5rem;
}

.main-title {
  margin-top: 15px;
  margin-bottom: 12px;
  margin-left: 15px;
  font-size: 20px;
  color: #89b4fa;
}

.artist {
  color: #cdd6f4;
  font-size: 13px;
  margin-left: 15px;
}

.music-slider {
  margin-top: 10px;
}

.music-slider trough {
  all: unset;
  background-color: rgba(0, 0, 0, 0.3);
  box-shadow: none;
  border-radius: 50px;
  min-height: 5px;
  min-width: 270px;
  margin: 0 20px 0 20px;
}

.music-slider trough highlight {
  all: unset;
  background-color: #89b4fa;
  border-radius: 10px;
}

.music-timer {
  color: #cdd6f4;
  margin: 3px 20px;
}

.mico {
  font-size: 30px;
  margin-left: 10px;
  transition: color 0.3s;

  &:hover {
    color: #89b4fa;
  }
}

.vol-mini trough {
  all: unset;
  margin-left: 7px;
  background-color: rgba(70, 70, 70, 0.4);
  border-radius: 50px;
  min-height: 5px;
  min-width: 100px;
}

.vol-mini trough highlight {
  all: unset;
  background-color: rgb(144, 104, 220);
  border-radius: 10px;
}
.battery { color: #cba6f7; }
.volume-short { color: #fab387; }
.ram-short { color: #a6e3a1; }
.keyboard { color: #f9e2af; }
