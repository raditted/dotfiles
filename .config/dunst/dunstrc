[global]
    monitor = 0
    follow = mouse
    
    # Position & Size
    width = 300
    height = (100, 100)
    origin = top-right
    offset = (20, 20)
    scale = 0
    notification_limit = 5
    
    # Progress Bar (e.g., for Volume/Brightness)
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 4
    
    # Spacing & Padding
    indicate_hidden = yes
    transparency = 5
    separator_height = 2
    padding = 16
    horizontal_padding = 16
    text_icon_padding = 16
    frame_width = 2
    gap_size = 8
    separator_color = frame
    sort = yes
    
    # Text & Font
    font = Inter 11
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    
    # Icons
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    enable_recursive_icon_lookup = true
    #icon_theme = "Papirus-Dark"
    
    # Border Radius
    corner_radius = 10
    
    # Mouse Actions
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

# --- CATPPUCCIN MOCHA THEME ---

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa" # Blue
    timeout = 4

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#cba6f7" # Purple
    timeout = 5

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#f38ba8" # Red
    timeout = 0
